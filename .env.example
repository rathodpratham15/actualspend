# Copy to .env.local and fill in. Never commit .env.local.

# --- Database (Neon Postgres) ---
DATABASE_URL=

# --- Auth.js / Google OAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Plaid ---
# https://dashboard.plaid.com/developers/keys
# PLAID_ENV controls which Plaid environment we hit and which secret to use:
#   sandbox     — free, fake data, no application required.
#   development — real banks, capped at 100 Items, free, no application.
#   production  — real banks, unlimited Items, requires Plaid approval
#                 (Production access request from dashboard.plaid.com).
# When switching envs you also need to update PLAID_SECRET to the matching
# secret from the dashboard. Existing link tokens / Items from a different
# env will not work — users must re-link their bank.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Plaid webhook URL (set in dashboard → Team Settings → Webhooks).
# Must be a publicly reachable URL — use ngrok or similar for local dev.
# When set, near-real-time transaction updates land without manual sync.
# PLAID_WEBHOOK_URL=https://yourdomain.com/api/plaid/webhook

# Set to "false" to bypass webhook JWT signature verification (dev only —
# leave unset in production so verification stays on).
# PLAID_WEBHOOK_VERIFY=false

# --- Rate limiting (Upstash Redis) ---
# Free tier at upstash.com covers ~10k commands/day. Without these set,
# rate limiting silently no-ops (fine for dev; required for prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- At-rest token encryption ---
# Wraps Plaid + Splitwise access tokens with AES-256-GCM before they're
# stored in the DB. Generate with: openssl rand -base64 32
# REQUIRED in production. Without it, /api/plaid/exchange and
# /api/splitwise/callback will throw.
ENCRYPTION_KEY=

# --- Error monitoring (Sentry) ---
# Sign up at sentry.io, grab the DSN from project settings.
# SENTRY_DSN is server-side; NEXT_PUBLIC_SENTRY_DSN is the browser one (can
# be the same DSN). When unset, Sentry init no-ops.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload during build (optional but recommended for prod):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Splitwise (OAuth2) ---
# https://secure.splitwise.com/oauth_clients
SPLITWISE_CLIENT_ID=
SPLITWISE_CLIENT_SECRET=
SPLITWISE_REDIRECT_URI=http://localhost:3000/api/splitwise/callback
